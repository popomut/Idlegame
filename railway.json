{
  "services": {
    "backend": {
      "root": "backend",
      "buildCommand": "go build -o idlegame-backend",
      "startCommand": "./idlegame-backend",
      "enviromentVariables": {
        "PORT": "3000"
      }
    },
    "frontend": {
      "root": "frontend",
      "buildCommand": "npm install && npm run build",
      "startCommand": "npm run preview",
      "environments": {
        "VITE_API_BASE_URL": "http://localhost:3000"
      }
    }
  }
}
